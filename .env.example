# Google Gemini APIキー (推奨)
# https://aistudio.google.com/ でAPIキーを取得してください
GOOGLE_API_KEY=

# Anthropic APIキー (任意)
# https://console.anthropic.com/ で取得（最低$5の課金が必要）
ANTHROPIC_API_KEY=

# データベース接続 (PostgreSQL推奨、未設定時はSQLite)
# docker compose up -d で起動した場合のデフォルト値:
DATABASE_URL=postgresql://grading:grading_dev@localhost:5432/grading

# JWT認証
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# 保存時暗号化 (Fernet鍵。未設定時は暗号化無効)
# 生成: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# 初期管理者ユーザー (seed-admin コマンドで使用)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
